{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start:server": "node dist/index.js",
    "start:worker:parse": "node dist/workers/parseWorker.js",
    "start:worker:scrape": "node dist/workers/scrapeWorker.js",
    "start:worker:ai": "node dist/workers/aiWorker.js",
    "start:scheduler": "node dist/workers/scheduler.js",
    "start": "concurrently -n server,parse,scrape,ai,scheduler \"npm:start:server\" \"npm:start:worker:parse\" \"npm:start:worker:scrape\" \"npm:start:worker:ai\" \"npm:start:scheduler\"",
    "dev:server": "nodemon --exec \"tsx src/index.ts\"",
    "dev": "concurrently -n server,parse,scrape,ai,scheduler \"npm:dev:server\" \"npm:worker:parse\" \"npm:worker:scrape\" \"npm:worker:ai\" \"npm:scheduler\"",
    "test": "vitest",
    "worker:parse": "tsx src/workers/parseWorker.ts",
    "worker:scrape": "tsx src/workers/scrapeWorker.ts",
    "worker:ai": "tsx src/workers/aiWorker.ts",
    "scheduler": "tsx src/workers/scheduler.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@aws-sdk/s3-request-presigner": "^3.1008.0",
    "@bull-board/express": "^6.20.5",
    "@langchain/anthropic": "^1.3.23",
    "@langchain/core": "^1.1.32",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.2.13",
    "@types/pg": "^8.18.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "got": "^14.6.6",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.2.32",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "uuid": "^11.0.3",
    "winston": "^3.19.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^6.0.2",
    "@types/validator": "^13.15.10",
    "@types/ws": "^8.5.13",
    "babel-plugin-module-resolver": "^5.0.2",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "nodemon": "^3.1.14",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
